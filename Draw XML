<mxfile host="app.diagrams.net">
  <diagram name="Release Management Flow">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start -->
        <mxCell id="start" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Create Release -->
        <mxCell id="create" value="Create Release\n(Product Request + RM creates in Helix)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="380" y="100" width="240" height="70" as="geometry"/>
        </mxCell>

        <!-- Initiate Release -->
        <mxCell id="initiate" value="Initiate Release\n- CRQ mapping/creation\n- HLD/SDD/ISCL attached\n- RTP from QA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;" vertex="1" parent="1">
          <mxGeometry x="360" y="200" width="280" height="110" as="geometry"/>
        </mxCell>

        <!-- Deploy Release -->
        <mxCell id="deploy" value="Deploy Release\n- KT to Ops\n- Approvals (CM/AP/AO)\n- Preprod\n- Go/No-Go\n- Prod Deploy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;" vertex="1" parent="1">
          <mxGeometry x="360" y="340" width="280" height="130" as="geometry"/>
        </mxCell>

        <!-- Close Release -->
        <mxCell id="close" value="Close Release\n- Helix closure\n- Retrospective if failure/backout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;" vertex="1" parent="1">
          <mxGeometry x="380" y="500" width="240" height="80" as="geometry"/>
        </mxCell>

        <!-- End -->
        <mxCell id="end" value="End" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;" vertex="1" parent="1">
          <mxGeometry x="450" y="610" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" edge="1" parent="1" source="start" target="create" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e2" edge="1" parent="1" source="create" target="initiate" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e3" edge="1" parent="1" source="initiate" target="deploy" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e4" edge="1" parent="1" source="deploy" target="close" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="e5" edge="1" parent="1" source="close" target="end" style="endArrow=block;html=1;">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
