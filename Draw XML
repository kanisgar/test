        <!-- Step 3 -->
        <mxCell id="s3" value="Move to Planning in Progress&#xa;Owner: Change Requestor&#xa;Status: Planning in Progress" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
