        <!-- Step 2 -->
        <mxCell id="s2" value="Add Mandatory Documents&#xa;Owner: Change Requestor&#xa;Status: Draft" style="rounded=1;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="200" width="320" height="70" as="geometry"/>
